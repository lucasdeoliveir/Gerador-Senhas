{
  "name": "gerador-senhas",
  "version": "1.0.0",
  "description": "Gerador de senhas seguras — aplicação web simples sem dependências de produção.",
  "main": "src/password-generator.js",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "echo 'Lint: sem linter configurado neste MVP'",
    "start": "npx serve src -l 3000"
  },
  "keywords": [
    "password",
    "generator",
    "security",
    "crypto",
    "javascript"
  ],
  "author": "SEU_NOME",
  "license": "MIT",
  "devDependencies": {
    "@peculiar/webcrypto": "^1.4.5",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/password-generator.js"
    ]
  }
}
